# Copy to `.env` and fill in real values. NEVER commit `.env`.

# --- Application ---
APP_NAME="LinkedIn Thought-Leadership Agent"
ENVIRONMENT=development          # development | production | test
DEBUG=false
LOG_LEVEL=INFO

# --- Security ---
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/linkedin_agent
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Ollama (local LLM) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- ChromaDB (embeddings) ---
CHROMA_HOST=http://localhost:8001

# --- Collector sources (Phase 2) ---
GITHUB_TOKEN=
DEVTO_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=linkedin-agent/0.1 by u/yourname
REDDIT_SUBREDDITS=programming,technology,MachineLearning
COLLECTOR_PER_SOURCE_LIMIT=25
COLLECTOR_MAX_CONCURRENCY=5
DEDUP_TITLE_THRESHOLD=90

# --- LinkedIn (Phase 8) ---
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=urn:li:person:xxxx
