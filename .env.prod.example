# Production .env — copy to `.env` on the server and fill in real values.
# NEVER commit the real .env. Compose service names resolve on the internal
# network, so DATABASE_URL / OLLAMA_HOST / WAHA_BASE_URL are injected by
# docker-compose.prod.yml — do NOT set them here.

# --- Application ---
APP_NAME="LinkedIn Thought-Leadership Agent"
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# --- Security ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_STRONG_RANDOM
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- Ollama (model auto-pulled by the ollama-pull service) ---
OLLAMA_MODEL=llama3.2:3b
OLLAMA_NUM_PREDICT=400
OLLAMA_KEEP_ALIVE=30m
# Oracle Ampere A1 free tier = 4 ARM cores. Match physical cores.
OLLAMA_NUM_THREAD=4

# --- LinkedIn ---
LINKEDIN_ACCESS_TOKEN=CHANGE_ME
LINKEDIN_AUTHOR_URN=urn:li:person:CHANGE_ME

# --- Notifications ---
NOTIFICATION_CHANNELS=log,whatsapp
# MUST be the public https URL of your cloudflared tunnel (no trailing slash),
# so the WhatsApp approve links open from your phone anywhere.
PUBLIC_BASE_URL=https://linkedin-agent.example.com

# --- WhatsApp / WAHA ---
# WAHA_BASE_URL is set by compose (http://waha:3000) — don't set it here.
WAHA_API_KEY=CHANGE_ME_RANDOM_HEX
WAHA_SESSION=linkedin-agent
WHATSAPP_RECIPIENT=918849552884@c.us

# --- Cloudflare tunnel ---
# Token from: Zero Trust > Networks > Tunnels > (your tunnel) > install connector.
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME

# --- Automation / scheduler ---
AUTO_PUBLISH_ON_APPROVE=true
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Kolkata
DAILY_PIPELINE_HOUR=10
DAILY_PIPELINE_MINUTE=0
DAILY_TOP_N=3
WEEKLY_REPORT_DAY=mon
WEEKLY_REPORT_HOUR=9
